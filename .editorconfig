root = true

# Baseline conventions for every file in the library. Editors that honor
# EditorConfig (most do, some via a plugin) will apply these automatically so
# 177+ guides and the scripts stay consistent.

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# Markdown is the bulk of the repo. Trailing whitespace can be meaningful
# (two trailing spaces = hard line break), so do not trim it here.
[*.md]
indent_size = 2
trim_trailing_whitespace = false

[*.py]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.sh]
indent_size = 2
